# Postgres connection string.
# Local:  postgresql://postgres:postgres@localhost:5432/medinsight
# Neon:   postgresql://user:password@ep-xxxx.neon.tech/medinsight?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medinsight

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Your Google Gemini API key — genuinely free tier, no credit card needed.
# Get one at https://aistudio.google.com/apikey (sign in with any Google account,
# click "Create API key"). Free tier limits are generous for a personal project.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:5173

# Port the Express server listens on locally (Vercel ignores this in production)
PORT=4000
